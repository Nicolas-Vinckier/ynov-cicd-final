# Copy this file to .env for local Docker Compose usage.
# The values below are placeholders for development only.
POSTGRES_USER=metrics_app
POSTGRES_PASSWORD=change-me-with-a-local-password
POSTGRES_DB=metrics

BACKEND_PORT=5000
FRONTEND_PORT=8080
CORS_ORIGIN=*

# Optional image names used by production deployment.
BACKEND_IMAGE=ghcr.io/<owner>/<repo>/metrics-api:latest
FRONTEND_IMAGE=ghcr.io/<owner>/<repo>/metrics-ui:latest
